# ===== File: .gitignore =====

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Databases / Data Volumes
qdrant_data/
mongo_data/
data/pdfs/*
!data/pdfs/.gitkeep

# IDEs
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Project Specific Exclusions
full_code_consolidated.txt
snapshot.py